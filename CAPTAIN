#property copyright "Copyright 2026"
#property version   "2.00"
#property strict

#include <Trade\Trade.mqh>

//================ INPUTS ================//
input group "Portfolio & Execution"
input string Symbols        = "EURUSD,GBPUSD,USDJPY,XAUUSD"; // List symbols (ensure names match broker)
input int MaxTradesPerDay   = 5;
input int CooldownMinutes   = 30;
input int MaxSpread         = 35;
input int MaxOpenTrades     = 3;

input group "Pattern Logic"
input int    Geo_MinBars      = 10;
input double FlatToleranceATR = 0.15;
input double BreakBufferATR   = 0.20;
input double MinBodyATR       = 0.10;

input group "Risk & ATR"
input double BaseRisk            = 1.0;
input double ATR_SL_Mult         = 1.5;
input double ATR_TP_Mult         = 3.0;
input double DailyLossLimit      = 3.0;
input double MaxDrawdown         = 6.0;

//================ GLOBALS ================//
CTrade trade;
string symbols[];
int    atrH[];
datetime lastBar[], lastTradeTime[];

double initialEquity, dayStartEquity, peakEquity;
int    tradesToday = 0;
bool   halted = false;

//+------------------------------------------------------------------+
//| INIT                                                             |
//+------------------------------------------------------------------+
int OnInit()
{
   int count = StringSplit(Symbols, ',', symbols);
   ArrayResize(atrH, count);
   ArrayResize(lastBar, count);
   ArrayResize(lastTradeTime, count);

   for(int i=0; i<count; i++)
   {
      symbols[i] = symbols[i];
      StringTrimLeft(symbols[i]); StringTrimRight(symbols[i]);
      SymbolSelect(symbols[i], true);
      atrH[i] = iATR(symbols[i], _Period, 14);
      lastBar[i] = 0;
      lastTradeTime[i] = 0;
   }

   trade.SetExpertMagicNumber(202600);
   initialEquity = AccountInfoDouble(ACCOUNT_EQUITY);
   dayStartEquity = initialEquity;
   peakEquity = initialEquity;

   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| MAIN LOOP                                                        |
//+------------------------------------------------------------------+
void OnTick()
{
   // 1. Daily Reset
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   static int lastD = -1;
   if(dt.day != lastD) { tradesToday = 0; dayStartEquity = AccountInfoDouble(ACCOUNT_EQUITY); lastD = dt.day; halted = false; }

   // 2. Risk Circuit Breaker
   double eq = AccountInfoDouble(ACCOUNT_EQUITY);
   if(eq > peakEquity) peakEquity = eq;
   if((dayStartEquity - eq) / dayStartEquity * 100.0 >= DailyLossLimit) halted = true;
   if((peakEquity - eq) / peakEquity * 100.0 >= MaxDrawdown) halted = true;
   if(halted || tradesToday >= MaxTradesPerDay) return;

   // 3. Scan Symbols
   for(int i=0; i<ArraySize(symbols); i++)
   {
      string sym = symbols[i];
      if(PositionSelect(sym) || !IsNewBar(sym, i)) continue;
      if(TimeCurrent() - lastTradeTime[i] < CooldownMinutes * 60) continue;
      if(SymbolInfoInteger(sym, SYMBOL_SPREAD) > MaxSpread) continue;

      double atrNow = GetATR(i);
      if(atrNow <= 0) continue;

      // Pattern Detection Logic
      int shift = 1;
      int end = shift + 1;
      int start = end + Geo_MinBars;

      double hS = GetSlope(sym, start, end, true);
      double lS = GetSlope(sym, start, end, false);
      double tol = FlatToleranceATR * atrNow;

      bool buy = false, sell = false;
      string pat = "";

      // Geometric Identification
      if(MathAbs(hS) < tol && lS > tol) pat = "AscTriangle";
      else if(MathAbs(lS) < tol && hS < -tol) pat = "DescTriangle";
      else if(MathAbs(hS) < tol && MathAbs(lS) < tol) pat = "Rectangle";
      else if(hS < -tol && lS > tol) pat = "Pennant";

      if(pat == "") continue;

      // Breakout Confirmation
      double res = iHigh(sym, _Period, iHighest(sym, _Period, MODE_HIGH, start - end + 1, end));
      double sup = iLow(sym, _Period, iLowest(sym, _Period, MODE_LOW, start - end + 1, end));
      
      if(pat == "AscTriangle" || pat == "Rectangle" || pat == "Pennant")
         buy = ConfirmBreak(sym, true, res, shift, atrNow);
      
      if(pat == "DescTriangle" || pat == "Rectangle" || pat == "Pennant")
         sell = ConfirmBreak(sym, false, sup, shift, atrNow);

      if(buy || sell) 
         ExecuteTrade(sym, buy, atrNow, pat, i);
   }
}

//+------------------------------------------------------------------+
//| HELPERS                                                          |
//+------------------------------------------------------------------+
bool IsNewBar(string sym, int i)
{
   datetime t = iTime(sym, _Period, 0);
   if(t == lastBar[i]) return false;
   lastBar[i] = t;
   return true;
}

double GetATR(int i)
{
   double b[]; ArraySetAsSeries(b, true);
   if(CopyBuffer(atrH[i], 0, 0, 1, b) < 1) return 0;
   return b[0];
}

double GetSlope(string sym, int start, int end, bool high)
{
   int n = start - end + 1;
   double sumX=0, sumY=0, sumXY=0, sumX2=0;
   for(int i=0; i<n; i++) {
      double p = high ? iHigh(sym, _Period, start-i) : iLow(sym, _Period, start-i);
      sumX += i; sumY += p; sumXY += i*p; sumX2 += i*i;
   }
   double d = n*sumX2 - sumX*sumX;
   return (d == 0) ? 0 : (n*sumXY - sumX*sumY) / d;
}

bool ConfirmBreak(string sym, bool buy, double level, int shift, double atr)
{
   double cl = iClose(sym, _Period, shift);
   double body = MathAbs(iOpen(sym, _Period, shift) - cl);
   if(body < MinBodyATR * atr) return false;
   return buy ? (cl > level + BreakBufferATR*atr) : (cl < level - BreakBufferATR*atr);
}

void ExecuteTrade(string sym, bool buy, double atr, string pat, int i)
{
   double slDist = MathMax(atr * ATR_SL_Mult, SymbolInfoInteger(sym, SYMBOL_TRADE_STOPS_LEVEL) * SymbolInfoDouble(sym, SYMBOL_POINT));
   double riskEntry = AccountInfoDouble(ACCOUNT_EQUITY) * (BaseRisk / 100.0);
   double tickVal = SymbolInfoDouble(sym, SYMBOL_TRADE_TICK_VALUE);
   double lot = riskEntry / ((slDist / SymbolInfoDouble(sym, SYMBOL_TRADE_TICK_SIZE)) * tickVal);
   
   // Normalize Lots
   double step = SymbolInfoDouble(sym, SYMBOL_VOLUME_STEP);
   lot = MathFloor(lot/step)*step;
   lot = MathMax(SymbolInfoDouble(sym, SYMBOL_VOLUME_MIN), MathMin(SymbolInfoDouble(sym, SYMBOL_VOLUME_MAX), lot));

   double price = buy ? SymbolInfoDouble(sym, SYMBOL_ASK) : SymbolInfoDouble(sym, SYMBOL_BID);
   double sl = buy ? price - slDist : price + slDist;
   double tp = buy ? price + atr * ATR_TP_Mult : price - atr * ATR_TP_Mult;

   if(trade.PositionOpen(sym, buy ? ORDER_TYPE_BUY : ORDER_TYPE_SELL, lot, price, sl, tp, "GEO_" + pat)) {
      lastTradeTime[i] = TimeCurrent();
      tradesToday++;
   }
}

